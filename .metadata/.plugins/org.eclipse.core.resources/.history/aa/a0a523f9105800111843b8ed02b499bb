<!DOCTYPE html>
<html class="light" lang="vi" xmlns:th="http://www.thymeleaf.org">
<head th:replace="~{fragments/head :: head_info}"></head>

<body class="bg-background-light dark:bg-background-dark h-screen flex overflow-hidden">
	<aside th:replace="~{fragments/sidebar :: sidebar}"></aside>
	<div class="flex-1 flex flex-col min-w-0">
		<header th:replace="~{fragments/header :: header}"></header>
		<main class="flex-1 flex flex-col h-full overflow-hidden bg-background-light dark:bg-background-dark relative">
			<div class="flex-1 p-8 max-w-[1600px] mx-auto w-full gap-6">
			    <div class="flex flex-col mb-6">
			        <h1 class="text-2xl font-black text-text-primary dark:text-white tracking-tight">Danh sách Đơn hàng</h1>
			        <p class="text-text-secondary text-sm mt-1">Quản lý Đơn hàng, thời gian tạo đơn và tổng tiền của từng đơn.</p>
			    </div>
			
			    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-4 mb-6 bg-white dark:bg-[#1e2936] p-5 rounded-xl border border-[#e5e7eb] dark:border-[#2a3441] shadow-sm">
			        <div class="flex flex-col md:flex-row gap-4 flex-1 w-full lg:w-auto">
			            <div class="flex flex-col gap-1.5 min-w-[400px]">
			                <label class="text-xs font-semibold text-[#637588] dark:text-[#9ca3af] uppercase">Tìm kiếm</label>
			                <div class="relative">
			                    <span class="material-symbols-outlined absolute left-3 top-2.5 text-[#9ca3af]">search</span>
			                    <input id="searchInput" th:value="${param.search}" class="w-full pl-10 pr-4 py-2 bg-[#f9fafb] dark:bg-[#111921] border border-[#dce0e5] dark:border-[#374151] rounded-lg text-sm text-[#111418] dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all" placeholder="Mã đơn, tên nhân viên, tên khách hàng..." type="text" />
			                </div>
			            </div>
			            <form method="get" class="flex flex-wrap gap-4 mb-6">
			                <input type="hidden" name="search" th:value="${param.search}" th:if="${param.search != null}"/>
			                
			                <div class="flex flex-col gap-1.5">
			                    <label class="text-xs font-semibold text-[#637588] dark:text-[#9ca3af] uppercase">Từ ngày</label>
			                    <input name="fromDate" th:value="${param.fromDate}" class="px-4 py-2 bg-[#f9fafb] dark:bg-[#111921] border border-[#dce0e5] dark:border-[#374151] rounded-lg text-sm text-[#111418] dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all" type="date" />
			                </div>
			                <div class="flex flex-col gap-1.5">
			                    <label class="text-xs font-semibold text-[#637588] dark:text-[#9ca3af] uppercase">Đến ngày</label>
			                    <input name="toDate" th:value="${param.toDate}" class="px-4 py-2 bg-[#f9fafb] dark:bg-[#111921] border border-[#dce0e5] dark:border-[#374151] rounded-lg text-sm text-[#111418] dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all" type="date" />
			                </div>
			                <div class="flex items-end">
			                    <button type="submit" class="h-[42px] px-4 bg-[#f0f2f4] dark:bg-[#374151] hover:bg-[#e5e7eb] dark:hover:bg-[#4b5563] text-[#111418] dark:text-white rounded-lg text-sm font-bold transition-colors flex items-center justify-center gap-2">
			                        <span class="material-symbols-outlined text-[20px]">filter_list</span>
			                        Lọc
			                    </button>
			                </div>
			            </form> 
			        </div>
			        <div class="flex items-center self-center pt-4 lg:pt-0">
			            <a th:href="@{/admin/order/create}">
			                <button class="h-[42px] px-6 bg-primary hover:bg-blue-600 text-white shadow-lg shadow-blue-500/30 rounded-lg text-sm font-bold transition-all transform active:scale-95 flex items-center justify-center gap-2">
			                    <span class="material-symbols-outlined text-[20px]">add</span>
			                    Tạo đơn hàng mới
			                </button>
			            </a>
			        </div>
			    </div>
			    
			    <div class="bg-white dark:bg-[#1e2936] rounded-xl border border-[#e5e7eb] dark:border-[#2a3441] shadow-sm overflow-hidden flex flex-col">
			        <div class="overflow-x-auto">
			            <table class="w-full text-left border-collapse">
			                <thead>
			                    <tr class="bg-[#f9fafb] dark:bg-[#111921] border-b border-[#e5e7eb] dark:border-[#2a3441]">
			                        <th class="py-4 px-6 text-xs font-semibold uppercase text-[#637588] dark:text-[#9ca3af] tracking-wider w-[130px] text-center">Mã đơn hàng</th>
			                        <th class="py-4 px-6 text-xs font-semibold uppercase text-[#637588] dark:text-[#9ca3af] tracking-wider">Ngày tạo</th>
			                        <th class="py-4 px-6 text-xs font-semibold uppercase text-[#637588] dark:text-[#9ca3af] tracking-wider">Khách hàng</th>
			                        <th class="py-4 px-6 text-xs font-semibold uppercase text-[#637588] dark:text-[#9ca3af] tracking-wider">Nhân viên</th>
			                        <th class="py-4 px-6 text-xs font-semibold uppercase text-[#637588] dark:text-[#9ca3af] tracking-wider">Trạng thái</th>
			                        <th class="py-4 px-6 text-xs font-semibold uppercase text-[#637588] dark:text-[#9ca3af] tracking-wider text-right">Tổng tiền</th>
			                        <th class="py-4 px-6 text-xs font-semibold uppercase text-[#637588] dark:text-[#9ca3af] tracking-wider text-center w-[100px]">Hành động</th>
			                    </tr>
			                </thead>
			                <tbody class="divide-y divide-[#e5e7eb] dark:divide-[#2a3441]">
			                    <tr th:each="o : ${orders}" class="hover:bg-blue-50/50 dark:hover:bg-[#2d3748] transition-colors group">
			                        <td class="py-4 px-6 text-xm font-medium text-primary text-center" th:text="${o.orderID}"></td>
			                        <td class="py-4 px-6 text-xm text-[#111418] dark:text-[#e5e7eb]" th:text="${o.orderDate != null ? #temporals.format(o.orderDate, 'dd-MM-yyyy HH:mm') : ''}"></td>
			                        <td class="py-4 px-6 text-xm text-[#111418] dark:text-[#e5e7eb]" th:text="${o.customerName}"></td>
			                        <td class="py-4 px-6 text-xm text-[#111418] dark:text-[#e5e7eb]" th:text="${o.user != null ? o.user.fullName : ''}"></td>
			                        <td class="p-4">
			                            <span th:if="${o.status}" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xm font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">
			                                Đã thanh toán
			                            </span>
			                            <span th:unless="${o.status}" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xm font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400">
			                                Đã hủy
			                            </span>
			                        </td>
			                        <td class="py-4 px-6 text-sm font-semibold text-[#111418] dark:text-[#e5e7eb] text-right" th:text="${o.totalAmount != null ? #numbers.formatInteger(o.totalAmount, 0, 'COMMA') : ''}"></td>
			                        <td class="py-4 px-6 text-center">
			                            <a th:href="@{/OrderPage_65131467/Detail/{id}(id=${o.orderID})}">
			                                <button class="p-2 text-[#637588] hover:text-primary hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition-colors" title="Xem chi tiết">
			                                    <span class="material-symbols-outlined text-[20px]">visibility</span>
			                                </button>                                  
			                            </a>
			                            <button th:onclick="|openDeleteModal('${o.orderID}')|" class="p-1.5 text-text-secondary hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-900/30 rounded transition-colors" title="Hủy">
			                                <span class="material-symbols-outlined !text-lg">delete</span>
			                            </button>
			                        </td>
			                    </tr>
			                </tbody>
			            </table>
			        </div>
			        
			        <div th:if="${totalPages > 1}" class="bg-surface-light dark:bg-surface-dark px-4 py-3 flex items-center justify-between border-t border-border-light dark:border-gray-800">
			            <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
			                <div>
			                    <nav aria-label="Pagination" class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px"
			                         th:with="start=${currentPage - 2 > 1 ? currentPage - 2 : 1}, end=${currentPage + 2 < totalPages ? currentPage + 2 : totalPages}">
			                        
			                        <a th:if="${currentPage > 1}" 
			                           th:href="@{/OrderPage_65131467(page=${currentPage - 1}, search=${param.search}, fromDate=${param.fromDate}, toDate=${param.toDate})}"
			                           class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-text-secondary hover:bg-gray-50 dark:hover:bg-gray-700">
			                            <span class="sr-only">Previous</span>
			                            <span class="material-symbols-outlined !text-lg">chevron_left</span>
			                        </a>
			
			                        <th:block th:if="${start > 1}">
			                            <a th:href="@{/OrderPage_65131467(page=1, search=${param.search}, fromDate=${param.fromDate}, toDate=${param.toDate})}"
			                               class="bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 text-text-secondary hover:bg-gray-50 dark:hover:bg-gray-700 relative inline-flex items-center px-4 py-2 border text-sm font-medium">
			                                1
			                            </a>
			                            <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-400">
			                                ...
			                            </span>
			                        </th:block>
			
			                        <th:block th:each="i : ${#numbers.sequence(start, end)}">
			                            <span th:if="${i == currentPage}" class="z-10 bg-primary/10 border-primary text-primary relative inline-flex items-center px-4 py-2 border text-sm font-bold" th:text="${i}"></span>
			                            
			                            <a th:unless="${i == currentPage}" 
			                               th:href="@{/OrderPage_65131467(page=${i}, search=${param.search}, fromDate=${param.fromDate}, toDate=${param.toDate})}"
			                               class="bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 text-text-secondary hover:bg-gray-50 dark:hover:bg-gray-700 relative inline-flex items-center px-4 py-2 border text-sm font-medium"
			                               th:text="${i}">
			                            </a>
			                        </th:block>
			
			                        <th:block th:if="${end < totalPages}">
			                            <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-400">
			                                ...
			                            </span>
			                            <a th:href="@{/OrderPage_65131467(page=${totalPages}, search=${param.search}, fromDate=${param.fromDate}, toDate=${param.toDate})}"
			                               class="bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 text-text-secondary hover:bg-gray-50 dark:hover:bg-gray-700 relative inline-flex items-center px-4 py-2 border text-sm font-medium" th:text="${totalPages}">
			                            </a>
			                        </th:block>
			
			                        <a th:if="${currentPage < totalPages}" 
			                           th:href="@{/OrderPage_65131467(page=${currentPage + 1}, search=${param.search}, fromDate=${param.fromDate}, toDate=${param.toDate})}"
			                           class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-text-secondary hover:bg-gray-50 dark:hover:bg-gray-700">
			                            <span class="sr-only">Next</span>
			                            <span class="material-symbols-outlined !text-lg">chevron_right</span>
			                        </a>
			                    </nav>
			                </div>
			            </div>
			        </div>
			    </div>
			</div>
		</main>
	</div>
	<div id="deleteModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
	    <div class="bg-white dark:bg-gray-800 rounded-xl w-[360px] p-6 shadow-lg">
	        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">
	            Xác nhận xóa
	        </h3>
	        <p class="text-sm text-gray-600 dark:text-gray-300 mb-6">
	            Bạn có chắc muốn hủy đơn hàng này không? Hành động này không thể hoàn tác.
	        </p>
	
	        <div class="flex justify-end gap-3">
	            <button onclick="closeDeleteModal()" class="px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
	                Không
	            </button>
	            <button onclick="confirmDelete()" class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700">
	                Có
	            </button>
	        </div>
	    </div>
	</div>
	<script>
	    let deleteProductId = null;
	    const searchInput = document.getElementById('searchInput');
	    
	    searchInput.addEventListener('keydown', function (e) {
	        if (e.key === 'Enter') {
	            e.preventDefault();
	
	            const keyword = searchInput.value.trim();
	            const url = new URL(window.location.href);
	
	            if (keyword)
	                url.searchParams.set('search', keyword);
	            else
	                url.searchParams.delete('search');
	
	            url.searchParams.set('page', 1);
	
	            window.location.href = url.toString();
	        }
	    });
	
	    function openDeleteModal(id) {
	        deleteProductId = id;
	        document.getElementById('deleteModal').classList.remove('hidden');
	        document.getElementById('deleteModal').classList.add('flex');
	    }
	
	    function closeDeleteModal() {
	        deleteProductId = null;
	        document.getElementById('deleteModal').classList.add('hidden');
	        document.getElementById('deleteModal').classList.remove('flex');
	    }
	
	    function confirmDelete() {
	        if (!deleteProductId) return;

	        window.location.href = `/OrderPage_65131467/Cancel/${deleteProductId}`;
	    }
	</script>
</body>
</html>