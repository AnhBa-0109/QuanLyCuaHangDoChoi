<!DOCTYPE html>
<html class="light" lang="vi" xmlns:th="http://www.thymeleaf.org">
<head th:replace="~{fragments/head :: head_info}"></head>

<body class="bg-background-light dark:bg-background-dark h-screen flex overflow-hidden">

    <aside th:replace="~{fragments/sidebar :: sidebar}"></aside>

    <div class="flex-1 flex flex-col min-w-0">
        
        <header th:replace="~{fragments/header :: header}"></header>
        <main class="flex-1 flex flex-col h-full overflow-hidden bg-background-light dark:bg-background-dark relative">
		    <div class="flex-1 overflow-y-auto p-4 md:p-8">
		        <div class="mx-auto max-w-7xl flex flex-col gap-8 pb-10">
		            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
		                <div class="flex flex-col gap-1">
		                    <h1 class="text-[#111418] dark:text-white text-3xl md:text-4xl font-black leading-tight tracking-[-0.033em]">Thống kê</h1>
		                    <p class="text-[#637588] dark:text-gray-400 text-base font-normal">Tổng quan tình hình kinh doanh hôm nay</p>
		                </div>
		                <div class="flex gap-3">
		                    <div class="flex items-center bg-white dark:bg-[#111921] border border-[#dce0e5] dark:border-gray-700 rounded-lg px-3 py-2">
		                        <span class="material-symbols-outlined text-[#637588] text-[20px] mr-2">calendar_today</span>
		                        <span class="text-sm font-medium" th:text="|Hôm nay: ${#dates.format(#dates.createNow(), 'dd/MM/yyyy')}|">Hôm nay: 01/01/2024</span>
		                    </div>
		                </div>
		            </div>
		
		            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
		                <div class="flex flex-col gap-2 rounded-xl p-5 bg-white dark:bg-[#111921] border border-[#dce0e5] dark:border-gray-800 shadow-sm">
		                    <div class="flex items-center justify-between">
		                        <p class="text-[#637588] dark:text-gray-400 text-sm font-medium">Doanh thu hôm nay</p>
		                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-blue-50 dark:bg-blue-900/20 text-primary shrink-0">
		                            <span class="material-symbols-outlined text-[20px]">payments</span>
		                        </div>
		                    </div>
		                    <p class="text-[#111418] dark:text-white text-2xl font-bold leading-tight" 
		                       th:text="${#numbers.formatDecimal(todayRevenue, 0, 'COMMA', 0, 'POINT')}">0</p>
		                </div>
		                
		                <div class="flex flex-col gap-2 rounded-xl p-5 bg-white dark:bg-[#111921] border border-[#dce0e5] dark:border-gray-800 shadow-sm">
		                    <div class="flex items-center justify-between">
		                        <p class="text-[#637588] dark:text-gray-400 text-sm font-medium">Đơn hàng mới</p>
		                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-purple-50 dark:bg-purple-900/20 text-purple-600 shrink-0">
		                            <span class="material-symbols-outlined text-[20px]">shopping_cart</span>
		                        </div>
		                    </div>
		                    <p class="text-[#111418] dark:text-white text-2xl font-bold leading-tight" th:text="${todayOrders}">0</p>
		                </div>
		                
		                <div class="flex flex-col gap-2 rounded-xl p-5 bg-white dark:bg-[#111921] border border-[#dce0e5] dark:border-gray-800 shadow-sm">
		                    <div class="flex items-center justify-between">
		                        <p class="text-[#637588] dark:text-gray-400 text-sm font-medium">Tổng sản phẩm</p>
		                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-orange-50 dark:bg-orange-900/20 text-orange-600 shrink-0">
		                            <span class="material-symbols-outlined text-[20px]">inventory_2</span>
		                        </div>
		                    </div>
		                    <p class="text-[#111418] dark:text-white text-2xl font-bold leading-tight" th:text="${totalProducts}">0</p>
		                    <div class="flex items-center gap-1">
		                        <p class="text-[#637588] dark:text-gray-500 text-sm">Đang kinh doanh</p>
		                    </div>
		                </div>
		                
		                <div class="flex flex-col gap-2 rounded-xl p-5 bg-white dark:bg-[#111921] border border-[#dce0e5] dark:border-gray-800 shadow-sm">
		                    <div class="flex items-center justify-between">
		                        <p class="text-[#637588] dark:text-gray-400 text-sm font-medium">Sắp hết hàng</p>
		                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-red-50 dark:bg-red-900/20 text-red-600 shrink-0">
		                            <span class="material-symbols-outlined text-[20px]">warning</span>
		                        </div>
		                    </div>
		                    <p class="text-[#111418] dark:text-white text-2xl font-bold leading-tight" th:text="${lowStockProducts}">0</p>
		                    <div class="flex items-center gap-1">
		                        <th:block th:if="${lowStockProducts > 0}">
		                            <span class="material-symbols-outlined text-[16px] text-red-500">priority_high</span>
		                            <p class="text-red-500 text-sm font-medium">Cần nhập thêm</p>
		                        </th:block>
		                    </div>
		                </div>
		            </div>
		
		            <th:block th:if="${revenueLabels != null and not #lists.isEmpty(revenueLabels)}">
		                <div class="bg-white dark:bg-surface-dark rounded-xl shadow-sm border mt-8">
		                    <div class="p-6 border-b flex items-center justify-between">
		                        <h3 class="text-lg font-bold text-gray-900 dark:text-white">
		                            Biểu đồ doanh thu
		                        </h3>
		                        <div class="flex bg-gray-100 dark:bg-gray-800 rounded-lg p-1">
		                            <a th:href="@{/admin/dashboard(type='week')}"
		                               class="px-3 py-1 text-xs rounded-md"
		                               th:classappend="${chartType == 'week' ? 'bg-white dark:bg-gray-700 font-bold' : ''}">
		                                Tuần
		                            </a>
		                            <a th:href="@{/admin/dashboard(type='month')}"
		                               class="px-3 py-1 text-xs rounded-md"
		                               th:classappend="${chartType == 'month' ? 'bg-white dark:bg-gray-700 font-bold' : ''}">
		                                Tháng
		                            </a>
		                        </div>
		                    </div>
		                    <div class="p-6">
		                        <canvas id="revenueChart" height="120"></canvas>
		                    </div>
		                </div>
		            </th:block>
		            
		            <th:block th:unless="${revenueLabels != null and not #lists.isEmpty(revenueLabels)}">
		                <div class="bg-white rounded-xl p-6 mt-8 text-gray-500">
		                    Chưa có dữ liệu doanh thu
		                </div>
		            </th:block>
		
		            <div class="flex flex-col lg:flex-row gap-6">
		                <div class="flex-[2] flex flex-col rounded-xl border border-[#dce0e5] dark:border-gray-800 bg-white dark:bg-[#111921] shadow-sm overflow-hidden">
		                    <div class="p-6 border-b border-[#dce0e5] dark:border-gray-800 flex justify-between items-center">
		                        <h2 class="text-[#111418] dark:text-white text-lg font-bold">Sản phẩm bán chạy</h2>
		                    </div>
		                    <div class="overflow-x-auto">
		                        <table class="w-full text-left text-sm text-[#111418] dark:text-white">
		                            <thead class="bg-[#f0f2f4] dark:bg-gray-800 text-[#637588] dark:text-gray-400">
		                                <tr>
		                                    <th class="px-6 py-3 font-semibold w-16">#</th>
		                                    <th class="px-6 py-3 font-semibold">Sản phẩm</th>
		                                    <th class="px-6 py-3 font-semibold">Loại</th>
		                                    <th class="px-6 py-3 font-semibold text-right">Giá bán</th>
		                                    <th class="px-6 py-3 font-semibold text-right">Đã bán</th>
		                                </tr>
		                            </thead>
		                            <tbody class="divide-y divide-[#dce0e5] dark:divide-gray-800">
									    <tr th:each="p, iterStat : ${topProducts}" class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
									        <td class="px-6 py-4 font-bold text-[#637588] dark:text-gray-500" th:text="${iterStat.count}">1</td>
									        <td class="px-6 py-4">
									            <div class="flex items-center gap-3">
									                <div class="h-10 w-10 rounded bg-gray-200 bg-cover bg-center shrink-0 border border-gray-100 dark:border-gray-700" 
									                     th:style="|background-image: url('${#strings.isEmpty(p.product.imageUrl) ? '/images/default-image.png' : p.product.imageUrl}');|">
									                </div>
									                <div class="flex flex-col">
									                    <span class="font-medium" th:text="${p.product.productName}">Tên sản phẩm</span>
									                    <span class="text-xs text-[#637588]" th:text="${p.product.productCode}">Mã SP</span>
									                </div>
									            </div>
									        </td>
									        <td class="px-6 py-4">
									            <span class="inline-flex items-center rounded-md bg-blue-50 dark:bg-blue-900/30 px-2 py-1 text-xs font-medium text-blue-700 dark:text-blue-200 ring-1 ring-inset ring-blue-700/10"
									                  th:text="|${p.product.brand != null ? p.product.brand.brandName : 'N/A'} - ${p.product.category != null ? p.product.category.categoryName : 'N/A'}|">Brand - Category</span>
									        </td>
									        <td class="px-6 py-4 text-right font-medium" th:text="${#numbers.formatDecimal(p.product.sellPrice, 0, 'COMMA', 0, 'POINT')} + ' ₫'">0 ₫</td>
									        
									        <td class="px-6 py-4 text-right font-bold" th:text="${p.soldQuantity}">0</td>
									    </tr>
									</tbody>
		                        </table>
		                    </div>
		                </div>
		            </div>
		        </div>
		    </div>
		</main>

<script th:inline="javascript">

    const revenueLabels =[];
    const revenueValues =[];

    const ctx = document.getElementById('revenueChart');

    if (ctx) {
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: revenueLabels,
                datasets: [{
                    label: 'Doanh thu',
                    data: revenueValues,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                }
            }
        });
    }
</script>
    </div>

</body>
</html>