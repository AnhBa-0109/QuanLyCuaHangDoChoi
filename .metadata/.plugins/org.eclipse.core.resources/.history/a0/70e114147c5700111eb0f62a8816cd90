package khanh.ntu.Repositories;

import java.util.Date;
import java.util.List;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;

import khanh.ntu.models.Order;

public interface OrderRepository extends JpaRepository<Order, Integer>{
	@Query("SELECT SUM(o.totalAmount) FROM Order o WHERE DATE(o.createdDate) = CURRENT_DATE")
    Double getTodayRevenue();

    // 2. Đếm số lượng đơn hàng hôm nay
    @Query("SELECT COUNT(o) FROM Order o WHERE DATE(o.createdDate) = CURRENT_DATE")
    Integer countTodayOrders();

    // 3. (Gợi ý) Truy vấn dữ liệu biểu đồ
    // Với biểu đồ, thường chúng ta sẽ trả về dạng Object[] hoặc interface projection gồm 2 cột: Label (Ngày/Tháng) và Value (Doanh thu)
    @Query("SELECT FUNCTION('DATE_FORMAT', o.createdDate, '%d/%m') as label, SUM(o.totalAmount) as value " +
           "FROM Order o " +
           "WHERE o.createdDate >= :startDate " +
           "GROUP BY FUNCTION('DATE_FORMAT', o.createdDate, '%d/%m') " +
           "ORDER BY label ASC")
    List<Object[]> getRevenueChartData(Date startDate);
}
