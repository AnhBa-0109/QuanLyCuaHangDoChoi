package khanh.ntu.controllers;

import java.time.LocalDate;
import java.util.List;
import java.util.stream.Collectors;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.data.domain.Page;
import org.springframework.format.annotation.DateTimeFormat;
import org.springframework.stereotype.Controller;
import org.springframework.ui.ModelMap;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestParam;

import khanh.ntu.models.Order;
import khanh.ntu.models.OrderDTO;
import khanh.ntu.models.ProductSelectionDTO;
import khanh.ntu.services.OrderService;
import khanh.ntu.services.ProductService;

@Controller
public class OrderController {
	
	@Autowired
	private OrderService orderService;
	@Autowired
	private ProductService productService;
	
	@GetMapping("/admin/order")
	public String showOrderPage(@RequestParam(value = "search", required = false) String search,
            @RequestParam(value = "fromDate", required = false) @DateTimeFormat(iso = DateTimeFormat.ISO.DATE) LocalDate fromDate,
            @RequestParam(value = "toDate", required = false) @DateTimeFormat(iso = DateTimeFormat.ISO.DATE) LocalDate toDate,
            @RequestParam(value = "page", defaultValue = "1") int page,
            ModelMap m) {
		int pageSize = 5;
		Page<Order> orderPage = orderService.searchAndFilterOrders(search, fromDate, toDate, page, pageSize);

        m.addAttribute("orders", orderPage.getContent());
        m.addAttribute("currentPage", page);
        m.addAttribute("totalPages", orderPage.getTotalPages());

        return "order_template/orderPage";
	}
	
	@GetMapping("/admin/order/create")
    public String showCreateForm(ModelMap model) {
        OrderDTO orderDTO = new OrderDTO();
        
        List<ProductSelectionDTO> productList = productService.getAll().stream().map(p -> {
            ProductSelectionDTO dto = new ProductSelectionDTO();
            dto.setProductId(p.getProductId());
            dto.setProductName(p.getProductName()); 
            dto.setPrice(p.getSellPrice());
            dto.setImageUrl(p.getImageUrl());
            dto.setQuantity(p.getQuantity());
            dto.setSelected(p.getIsActive());
            return dto;
        }).collect(Collectors.toList());
        
        return "order_template/createOrder";
    }
	
	@PostMapping("/admin/order/create")
    public String createOrder(@ModelAttribute("order") Order order) {
        orderService.save(order);
        return "redirect:/admin/order";
    }
	
	
}
