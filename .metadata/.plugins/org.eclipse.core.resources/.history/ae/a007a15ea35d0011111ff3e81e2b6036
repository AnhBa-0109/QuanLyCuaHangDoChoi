<!DOCTYPE html>
<html class="light" lang="vi" xmlns:th="http://www.thymeleaf.org">
<head th:replace="~{fragments/head :: head_info}"></head>

<body class="bg-background-light dark:bg-background-dark h-screen flex overflow-hidden">

    <aside th:replace="~{fragments/sidebar :: sidebar}"></aside>

    <div class="flex-1 flex flex-col min-w-0">

        <header th:replace="~{fragments/header :: header}"></header>

        <main class="flex-1 overflow-y-auto">
            <div class="flex-1 p-8 max-w-[1600px] mx-auto w-full gap-6">
                <div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-sm border border-[#e5e7eb] dark:border-[#2d3b4a] overflow-hidden">

                    <div class="p-6 md:p-8 border-b border-[#e5e7eb] dark:border-[#2d3b4a]">
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                            <div>
                                <div class="flex items-center gap-3 mb-1">
					                <a th:href="@{/admin/order}" 
					                   class="p-2 text-[#637588] hover:text-primary hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition-colors"
					                   title="Quay lại">
					                    <span class="material-symbols-outlined text-[24px]">arrow_back</span>
					                </a>
					                <h1 class="text-2xl md:text-3xl font-bold text-[#111418] dark:text-white tracking-tight"
					                    th:text="'Hóa đơn #' + ${order.orderId}">Hóa đơn #</h1>
					                <span th:if="${order.status}"
									      class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 border border-green-200 dark:border-green-800">
									    Đã Thanh Toán
									</span>
									<span th:unless="${order.status}"
									      class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200 border border-red-200 dark:border-red-800">
									    Đã Hủy
									</span>
					            </div>
                                <p class="text-[#637588] dark:text-gray-400 text-sm"
                                   th:text="'Thời gian tạo ' + ${#temporals.format(order.orderDate, 'dd-MM-yyyy HH:mm')}"></p>
                            </div>
                        </div>
                    </div>

                    <!-- Description List (Info Grid) -->
                    <div class="p-6 md:p-8 bg-[#f9fafb] dark:bg-[#1a2632]/50 border-b border-[#e5e7eb] dark:border-[#2d3b4a]">
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-semibold text-[#637588] dark:text-gray-500 uppercase tracking-wider">Tên khách hàng</span>
                                <p class="text-[#111418] dark:text-gray-200 font-medium" th:text="${order.customerName}"></p>
                            </div>
                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-semibold text-[#637588] dark:text-gray-500 uppercase tracking-wider">Phương thức thanh toán</span>
                                <div class="flex items-center gap-2">
                                    <p class="text-[#111418] dark:text-gray-200 font-medium"
                                       th:if="${order.paymentMethod == 'Cash'}">Thanh toán tiền mặt</p>
                                    <p class="text-[#111418] dark:text-gray-200 font-medium"
                                       th:unless="${order.paymentMethod == 'Cash'}">Chuyển khoản</p>
                                </div>
                            </div>
                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-semibold text-[#637588] dark:text-gray-500 uppercase tracking-wider">Nhân viên đứng quầy</span>
                                <div class="flex items-center gap-2">
                                    <div class="size-6 rounded-full bg-gray-200 dark:bg-gray-600 bg-cover"
                                         th:style="'background-image: url(' + ${order.avatarUrl} + ');'"></div>
                                    <p class="text-[#111418] dark:text-gray-200 font-medium" th:text="${order.staffName}"></p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Product Table -->
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="border-b border-[#e5e7eb] dark:border-[#2d3b4a] bg-white dark:bg-surface-dark">
                                    <th class="py-4 pl-6 md:pl-8 pr-4 text-xs font-semibold text-[#637588] dark:text-gray-400 uppercase tracking-wider w-[40%]">Tên sản phẩm</th>
                                    <th class="py-4 px-4 text-xs font-semibold text-[#637588] dark:text-gray-400 uppercase tracking-wider">Brand/Loại</th>
                                    <th class="py-4 px-4 text-xs font-semibold text-[#637588] dark:text-gray-400 uppercase tracking-wider text-right">Giá tiền</th>
                                    <th class="py-4 px-4 text-xs font-semibold text-[#637588] dark:text-gray-400 uppercase tracking-wider text-center">Số lượng</th>
                                    <th class="py-4 pl-4 pr-6 md:pr-8 text-xs font-semibold text-[#637588] dark:text-gray-400 uppercase tracking-wider text-right">Tổng tiền</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white dark:bg-surface-dark divide-y divide-[#f0f2f4] dark:divide-[#2d3b4a]">
                                <tr th:each="item : ${order.products}"
                                    class="hover:bg-gray-50 dark:hover:bg-[#202e3b] transition-colors">
                                    <td class="py-4 pl-6 md:pl-8 pr-4">
                                        <div class="flex items-center gap-4">
                                            <div class="size-12 rounded-lg bg-gray-100 dark:bg-gray-700 flex-shrink-0 bg-cover bg-center border border-gray-200 dark:border-gray-600"
                                                 th:style="'background-image: url(' + ${item.imageUrl} + ');'"></div>
                                            <div class="flex flex-col">
                                                <span class="text-[#111418] dark:text-white font-medium text-sm" th:text="${item.productName}"></span>
                                                <span class="text-[#637588] dark:text-gray-400 text-xs" th:text="'SKU: ' + ${item.productCode}"></span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-4 px-4 text-sm text-[#637588] dark:text-gray-400 font-mono"
                                        th:text="${item.brandName} + ' - ' + ${item.categoryName}"></td>
                                    <td class="py-4 px-4 text-sm text-[#111418] dark:text-gray-200 text-right"
                                        th:text="${#numbers.formatInteger(item.price, 0, 'COMMA')} + ' ₫'"></td>
                                    <td class="py-4 px-4 text-sm text-[#111418] dark:text-gray-200 text-center"
                                        th:text="${item.quantity}"></td>
                                    <td class="py-4 pl-4 pr-6 md:pr-8 text-sm text-[#111418] dark:text-gray-200 font-semibold text-right"
                                        th:text="${#numbers.formatInteger(item.price * item.quantity, 0, 'COMMA')} + ' ₫'"></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Footer / Summary -->
                    <div class="flex flex-col md:flex-row justify-end items-end p-6 md:p-8 border-t border-[#e5e7eb] dark:border-[#2d3b4a]">
                        <div class="w-full md:w-1/2 lg:w-1/3 flex flex-col gap-3">
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-[#637588] dark:text-gray-400">Subtotal</span>
                                <span class="text-[#111418] dark:text-gray-200 font-medium"
                                      th:text="${#numbers.formatInteger(order.subTotal, 0, 'COMMA')} + ' ₫'"></span>
                            </div>
                            <div class="h-px bg-[#e5e7eb] dark:bg-[#2d3b4a] my-1"></div>
                            <div class="flex justify-between items-center">
                                <span class="text-[#111418] dark:text-white font-bold text-lg">Total Amount</span>
                                <span class="text-primary font-bold text-xl"
                                      th:text="${#numbers.formatInteger(order.total, 0, 'COMMA')} + ' ₫'"></span>
                            </div>
                            <div class="mt-4 pt-4 border-t border-dashed border-[#e5e7eb] dark:border-[#2d3b4a] text-center">
                                <p class="text-xs text-[#637588] dark:text-gray-500 italic">Thank you for shopping at AnhBar Hobby!</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </main>

    </div>
</body>
</html>