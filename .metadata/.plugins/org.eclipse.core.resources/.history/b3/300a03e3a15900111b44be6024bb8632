package khanh.ntu.controllers;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.ModelMap;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.multipart.MultipartFile;
import org.springframework.web.servlet.mvc.support.RedirectAttributes;

import khanh.ntu.models.User;
import khanh.ntu.services.UserService;

@Controller
public class EmployeeController {

	@Autowired
    private UserService userService;
	
	@GetMapping("/admin/employee")
    public String showEmployeePage(ModelMap model,
                                   @RequestParam(defaultValue = "") String search,
                                   @RequestParam(defaultValue = "1") int page) {
        int pageSize = 10;
        List<User> allUsers = userService.getAll().stream()
                .filter(u -> search.isEmpty()
                        || u.getFullName().toLowerCase().contains(search.toLowerCase())
                        || u.getUserId().toString().contains(search))
                .collect(java.util.stream.Collectors.toList());

        int totalPages = (int) Math.ceil((double) allUsers.size() / pageSize);
        int start = (page - 1) * pageSize;
        int end = Math.min(start + pageSize, allUsers.size());
        List<User> users = allUsers.subList(start, end);

        model.addAttribute("users", users);
        model.addAttribute("totalUsers", userService.countActiveUsers());
        model.addAttribute("totalPages", totalPages);
        model.addAttribute("currentPage", page);
        return "employee_template/employeePage";
    }
	
	@GetMapping("/admin/employee/create")
    public String showCreateForm(ModelMap model) {
        model.addAttribute("userCreate", new User());
        return "employee_template/createEmployee";
    }
	
	@PostMapping("/admin/employee/create")
	public String createEmployee(@ModelAttribute("userCreate") User user,
	                              @RequestParam("avatarFile") MultipartFile avatarFile,
	                              ModelMap model,
	                              RedirectAttributes redirectAttributes) {
	    try {
	        userService.save(user.getUsername(), user.getEmail(), user, avatarFile);
	        redirectAttributes.addFlashAttribute("success", "Thêm nhân viên thành công!");
	        return "redirect:/admin/employee";
	    } catch (Exception e) {
	        model.addAttribute("userCreate", user);
	        model.addAttribute("errorUsername", e.getMessage());
	        return "employee_template/createEmployee";
	    }
	}
	
	@GetMapping("/admin/employee/delete/{id}")
	public String delete(@PathVariable("id") Integer id, RedirectAttributes redirectAttributes) {
		userService.delete(id);
		redirectAttributes.addFlashAttribute("success", "Đã xóa nhân viên thành công!");
	    return "redirect:/admin/employee";
	}
	
	@GetMapping("/admin/employee/edit/{id}")
	public String edit(@PathVariable("id") Integer id, ModelMap m) {
		User user = userService.getById(id);
		m.addAttribute("userEdit", user);
		return "employee_template/editEmployee";
	}
}
