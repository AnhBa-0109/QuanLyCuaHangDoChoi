<!DOCTYPE html>
<html class="light" lang="vi" xmlns:th="http://www.thymeleaf.org">
<head th:replace="~{fragments/head :: head_info}"></head>

<body class="bg-background-light dark:bg-background-dark h-screen flex overflow-hidden">

    <aside th:replace="~{fragments/sidebar :: sidebar}"></aside>

    <div class="flex-1 flex flex-col min-w-0">
        
		<header th:replace="~{fragments/header :: header}"></header>
		<main class="flex-1 flex flex-col h-full overflow-hidden bg-background-light dark:bg-background-dark relative">
			<div class="container mx-auto px-8 py-6 flex flex-col gap-6">
			    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
			        <div class="flex flex-col gap-1">
			            <h1 class="text-[#111418] dark:text-white text-2xl font-black leading-tight tracking-[-0.033em]">Quản lý Danh mục</h1>
			            <p class="text-[#637588] dark:text-[#9ca3af] text-base font-normal leading-normal">Quản lý danh sách Thương hiệu và Loại sản phẩm cho cửa hàng.</p>
			        </div>
			    </div>
			    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 h-full pb-8">
			        <section class="flex flex-col bg-white dark:bg-[#1e2936] rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden h-fit">
			            <div class="p-5 border-b border-gray-100 dark:border-gray-700 flex flex-wrap items-center justify-between gap-4 bg-white dark:bg-[#1e2936]">
			                <div class="flex items-center gap-3">
			                    <div class="p-2 rounded-lg bg-blue-50 dark:bg-blue-900/30 text-primary">
			                        <span class="material-symbols-outlined" style="font-size: 24px;">verified</span>
			                    </div>
			                    <h2 class="text-[#111418] dark:text-white text-lg font-bold">Thương hiệu</h2>
			                </div>
			                <button onclick="openModal('brand', 'add', null)" class="flex items-center gap-2 bg-primary hover:bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
			                    <span class="material-symbols-outlined" style="font-size: 20px;">add</span>
			                    Thêm mới
			                </button>
			            </div>
			            <div class="flex flex-col max-h-[370px] overflow-y-auto">
			                <table class="min-w-full divide-y divide-gray-100 dark:divide-gray-700">
			                    <thead class="bg-gray-50 dark:bg-gray-800 sticky top-0 z-10">
			                        <tr>
			                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider w-16">Mã</th>
			                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Tên Brand</th>
			                            <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Sản phẩm</th>
			                            <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Thao tác</th>
			                        </tr>
			                    </thead>
			                    <tbody class="bg-white dark:bg-[#1e2936] divide-y divide-gray-100 dark:divide-gray-700">
			                        <tr th:each="b : ${brands}" class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
			                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400 font-mono" th:text="'#' + ${b.brandCode}">#BRANDCODE</td>
			                            <td class="px-6 py-4 whitespace-nowrap">
			                                <div class="flex items-center">
			                                    <div class="text-sm font-medium text-gray-900 dark:text-white" th:text="${b.brandName}">Tên Brand</div>
			                                </div>
			                            </td>
			                            <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500 dark:text-gray-400">
			                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800"
			                                      th:text="${brandProductCount != null ? brandProductCount.getOrDefault(b.brandId, 0) : 0}">
			                                    0
			                                </span>
			                            </td>
			                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
			                                <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
			                                    <button onclick="openModal('brand', 'edit', this.getAttribute('data-id'), this.getAttribute('data-name'), this.getAttribute('data-code'))"
			                                            th:data-id="${b.brandId}"
			                                            th:data-name="${b.brandName}"
			                                            th:data-code="${b.brandCode}"
			                                            class="text-indigo-600 hover:text-indigo-900 p-1 rounded hover:bg-indigo-50 dark:hover:bg-indigo-900/20" title="Edit">
			                                        <span class="material-symbols-outlined text-[20px]">edit</span>
			                                    </button>
			                                    <button onclick="openDeleteModal(this.getAttribute('data-id'), 'brand')"
			                                            th:data-id="${b.brandId}"
			                                            class="text-red-600 hover:text-red-900 p-1 rounded hover:bg-red-50 dark:hover:bg-red-900/20" title="Delete">
			                                        <span class="material-symbols-outlined text-[20px]">delete</span>
			                                    </button>
			                                </div>
			                            </td>
			                        </tr>
			                    </tbody>
			                </table>
			            </div>
			        </section>
			        <section class="flex flex-col bg-white dark:bg-[#1e2936] rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden h-fit">
			            <div class="p-5 border-b border-gray-100 dark:border-gray-700 flex flex-wrap items-center justify-between gap-4 bg-white dark:bg-[#1e2936]">
			                <div class="flex items-center gap-3">
			                    <div class="p-2 rounded-lg bg-orange-50 dark:bg-orange-900/30 text-orange-600">
			                        <span class="material-symbols-outlined" style="font-size: 24px;">category</span>
			                    </div>
			                    <h2 class="text-[#111418] dark:text-white text-lg font-bold">Loại sản phẩm</h2>
			                </div>
			                <button onclick="openModal('category', 'add', null)" class="flex items-center gap-2 bg-primary hover:bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
			                    <span class="material-symbols-outlined" style="font-size: 20px;">add</span>
			                    Thêm mới
			                </button>
			            </div>
			            <div class="flex flex-col max-h-[370px] overflow-y-auto">
			                <table class="min-w-full divide-y divide-gray-100 dark:divide-gray-700">
			                    <thead class="bg-gray-50 dark:bg-gray-800 sticky top-0 z-10">
			                        <tr>
			                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider w-16">Mã</th>
			                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Tên Loại</th>
			                            <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Sản phẩm</th>
			                            <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Thao tác</th>
			                        </tr>
			                    </thead>
			                    <tbody class="bg-white dark:bg-[#1e2936] divide-y divide-gray-100 dark:divide-gray-700">
			                        <tr th:each="c : ${categories}" class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
			                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400 font-mono" th:text="'#' + ${c.categoryCode}">#CATEGORYCODE</td>
			                            <td class="px-6 py-4 whitespace-nowrap">
			                                <div class="flex items-center">
			                                    <div class="text-sm font-medium text-gray-900 dark:text-white" th:text="${c.categoryName}">Tên Loại</div>
			                                </div>
			                            </td>
			                            <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500 dark:text-gray-400">
			                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800"
			                                      th:text="${categoryProductCount != null ? categoryProductCount.getOrDefault(c.categoryId, 0) : 0}">
			                                    0
			                                </span>
			                            </td>
			                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
			                                <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
			                                    <button onclick="openModal('category', 'edit', this.getAttribute('data-id'), this.getAttribute('data-name'), this.getAttribute('data-code'))"
			                                            th:data-id="${c.categoryId}"
			                                            th:data-name="${c.categoryName}"
			                                            th:data-code="${c.categoryCode}"
			                                            class="text-indigo-600 hover:text-indigo-900 p-1 rounded hover:bg-indigo-50 dark:hover:bg-indigo-900/20" title="Edit">
			                                        <span class="material-symbols-outlined text-[20px]">edit</span>
			                                    </button>
			                                    <button onclick="openDeleteModal(this.getAttribute('data-id'), 'category')"
			                                            th:data-id="${c.categoryId}"
			                                            class="text-red-600 hover:text-red-900 p-1 rounded hover:bg-red-50 dark:hover:bg-red-900/20" title="Delete">
			                                        <span class="material-symbols-outlined text-[20px]">delete</span>
			                                    </button>
			                                </div>
			                            </td>
			                        </tr>
			                    </tbody>
			                </table>
			            </div>
			        </section>
			    </div>
			</div>
		</main>
	</div>

		<div id="Modal" class="fixed inset-0 bg-black/40 hidden items-center justify-center z-50">
		    <div class="bg-white dark:bg-surface-dark rounded-xl p-6 w-96 flex flex-col gap-3">
		        <h3 id="modalTitle" class="text-lg font-bold mb-4"></h3>
		
		        <input id="modalNameInput" class="w-full h-12 px-4 rounded-lg border" placeholder="" />
		        <input id="modalCodeInput" class="w-full h-12 px-4 rounded-lg border" placeholder="" />
		        <div class="flex justify-end gap-2 mt-4">
		            <button type="button" onclick="closeModal()" class="px-4 py-2 border rounded-lg">Hủy</button>
		            <button type="button" onclick="saveItem()" class="px-4 py-2 bg-primary text-white rounded-lg">Lưu</button>
		        </div>
		    </div>
		</div>
		
		<div id="deleteModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
		    <div class="bg-white dark:bg-gray-800 rounded-xl w-[360px] p-6 shadow-lg">
		        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Xác nhận xóa</h3>
		        <p class="text-sm text-gray-600 dark:text-gray-300 mb-6">Bạn có chắc muốn xóa không? Hành động này không thể hoàn tác.</p>
		
		        <div class="flex justify-end gap-3">
		            <button onclick="closeDeleteModal()" class="px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">Không</button>
		            <button onclick="confirmDelete()" class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700">Có</button>
		        </div>
		    </div>
		</div>
	
	<div id="Modal" class="fixed inset-0 bg-black/40 hidden items-center justify-center z-50">
	    <div class="bg-white dark:bg-surface-dark rounded-xl p-6 w-96 flex flex-col gap-3">
	        <h3 id="modalTitle" class="text-lg font-bold mb-4"></h3>
	
	        <input id="modalNameInput" class="w-full h-12 px-4 rounded-lg border" placeholder="" />
	        <input id="modalCodeInput" class="w-full h-12 px-4 rounded-lg border" placeholder="" />
	        <div class="flex justify-end gap-2 mt-4">
	            <button type="button" onclick="closeModal()" class="px-4 py-2 border rounded-lg">Hủy</button>
	            <button type="button" onclick="saveItem()" class="px-4 py-2 bg-primary text-white rounded-lg">Lưu</button>
	        </div>
	    </div>
	</div>
	
	<div id="deleteModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
	    <div class="bg-white dark:bg-gray-800 rounded-xl w-[360px] p-6 shadow-lg">
	        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Xác nhận xóa</h3>
	        <p class="text-sm text-gray-600 dark:text-gray-300 mb-6">Bạn có chắc muốn xóa không? Hành động này không thể hoàn tác.</p>
	
	        <div class="flex justify-end gap-3">
	            <button onclick="closeDeleteModal()" class="px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">Không</button>
	            <button onclick="confirmDelete()" class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700">Có</button>
	        </div>
	    </div>
	</div>
	
	<script th:inline="javascript">
	    let currentType = ""; 
	    let currentId = null;
	    let currentMode = "";
	
	    function openModal(type, mode, id, name = '', code = '') {
	        currentType = type;
	        currentMode = mode;
	        currentId = id;
	        console.log("Dữ liệu ID hiện tại:", currentId);
	        
	        const titlePrefix = (mode === 'edit' ? 'Chỉnh sửa ' : 'Thêm mới ');
	        document.getElementById('modalTitle').innerText = titlePrefix + (type === 'brand' ? 'Brand' : 'Category');
	
	        document.getElementById('modalNameInput').value = name;
	        document.getElementById('modalCodeInput').value = code;
	
	        document.getElementById('modalNameInput').placeholder = type === 'brand' ? 'Tên Brand' : 'Tên Category';
	        document.getElementById('modalCodeInput').placeholder = type === 'brand' ? 'Brand Code' : 'Category Code';
	
	        document.getElementById('Modal').classList.remove('hidden');
	        document.getElementById('Modal').classList.add('flex');
	    }
	
	    function closeModal() {
	        document.getElementById('Modal').classList.add('hidden');
	        document.getElementById('Modal').classList.remove('flex');
	    }
	
	    function saveItem() {
	        const name = document.getElementById('modalNameInput').value.trim();
	        const code = document.getElementById('modalCodeInput').value.trim();
	
	        if (!name || !code) {
	            alert('Không được để trống');
	            return;
	        }

	        let url = '';
	        if (currentType === 'brand') {
	            url = currentMode === 'add' ? '/admin/brand/create' : '/admin/brands/edit';
	        } else {
	            url = currentMode === 'add' ? '/admin/category/create' : '/admin/categories/edit';
	        }

	        const bodyData = {
	            brandId: currentType === 'brand' ? currentId : null,
	            brandName: currentType === 'brand' ? name : null,
	            brandCode: currentType === 'brand' ? code : null,
	            categoryId: currentType === 'category' ? currentId : null,
	            categoryName: currentType === 'category' ? name : null,
	            categoryCode: currentType === 'category' ? code : null
	        };
	
	        fetch(url, {
	            method: 'POST',
	            headers: { 'Content-Type': 'application/json' },
	            body: JSON.stringify(bodyData)
	        })
	        .then(res => res.json())
	        .then(data => {
	            if (data.error) {
	                alert(data.error);
	                return;
	            }
	            closeModal();
	            window.location.reload();
	        })
	        .catch(err => {
	            console.error(err);
	            alert("Có lỗi xảy ra: " + err.message);
	        });
	    }
	
	    function openDeleteModal(id, type) {
	        currentType = type;
	        currentId = id;
	        document.getElementById('deleteModal').classList.remove('hidden');
	        document.getElementById('deleteModal').classList.add('flex');
	    }
	
	    function closeDeleteModal() {
	        currentId = null;
	        currentType = "";
	        document.getElementById('deleteModal').classList.add('hidden');
	        document.getElementById('deleteModal').classList.remove('flex');
	    }
	
	    function confirmDelete() {
	        if (!currentId || !currentType) return;
	
	        if (currentType === 'brand') {
	            window.location.href = `/admin/brands/delete/${currentId}`;
	        } else {
	            window.location.href = `/admin/categories/delete/${currentId}`;
	        }
	    }
	</script>
</body>
</html>