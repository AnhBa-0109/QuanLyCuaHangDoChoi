<form th:action="@{/admin/products/save}" th:object="${product}" method="post" enctype="multipart/form-data">
    
    <input type="hidden" th:field="*{productId}" />
    <input type="hidden" th:field="*{imageUrl}" />
    <input type="hidden" th:field="*{productCode}" />

    <div class="w-48 h-48 bg-center bg-contain bg-no-repeat bg-gray-100 border rounded-lg" 
         th:style="'background-image: url(' + *{imageUrl} + ');'">
    </div>
    
    <label class="flex flex-col gap-2 mt-4">
        <span class="text-sm font-semibold">Tên sản phẩm *</span>
        <input type="text" th:field="*{productName}" class="h-12 px-4 rounded-lg border border-gray-300" />
    </label>
    
    <div class="flex justify-end mt-4">
        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg font-bold">Cập nhật</button>
    </div>
</form>