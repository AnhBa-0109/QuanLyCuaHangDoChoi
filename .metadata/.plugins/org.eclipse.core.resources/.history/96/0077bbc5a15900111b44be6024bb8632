<!DOCTYPE html>
<html class="light" lang="vi" xmlns:th="http://www.thymeleaf.org">
<head th:replace="~{fragments/head :: head_info}"></head>

<body class="bg-background-light dark:bg-background-dark h-screen flex overflow-hidden">
    <aside th:replace="~{fragments/sidebar :: sidebar}"></aside>
    <div class="flex-1 flex flex-col min-w-0">
        <header th:replace="~{fragments/header :: header}"></header>
        <main class="flex-1 overflow-y-auto">
            <div class="max-w-7xl mx-auto p-8">
                <div class="flex flex-col gap-1 mb-8">
                    <div class="flex items-center justify-between flex-wrap gap-4">
                        <div>
                            <h1 class="text-2xl font-black tracking-tight text-text-main-light dark:text-text-main-dark">Chi tiết nhân viên</h1>
                            <p class="text-text-secondary-light dark:text-text-secondary-dark mt-2">Xem và chỉnh sửa thông tin hồ sơ nhân viên</p>
                        </div>
                    </div>
                </div>

                <form th:action="@{/admin/employee/edit}" th:object="${userEdit}" 
                      method="post" enctype="multipart/form-data">

                    <input type="hidden" th:field="*{userId}" />

                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

                        <div class="col-span-1">
                            <div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-sm border border-border-light dark:border-border-dark p-6 flex flex-col items-center text-center">
                                <div class="relative group cursor-pointer mb-4" id="avatarContainer">
                                    <div id="avatarPreview" 
                                         class="size-32 rounded-full bg-cover bg-center border-4 border-white dark:border-surface-dark shadow-md"
                                         th:style="'background-image: url(' + *{avatarUrl} + ');'">
                                    </div>
                                    <div class="absolute inset-0 rounded-full bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                        <span class="material-symbols-outlined text-white">camera_alt</span>
                                    </div>
                                    <input type="file" id="avatarInput" name="avatarFile" class="hidden" accept="image/*" />
                                </div>
                                <h2 class="text-xl font-bold text-text-main-light dark:text-text-main-dark" th:text="*{fullName}"></h2>
                                <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark mb-4" th:text="'Mã NV: ' + *{userId}"></p>
                            </div>
                        </div>

                        <div class="col-span-1 lg:col-span-2">
                            <div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-sm border border-border-light dark:border-border-dark overflow-hidden flex flex-col h-full">
                                <div class="p-6 md:p-8 flex-1">
                                    <h3 class="text-lg font-bold text-text-main-light dark:text-text-main-dark mb-6">Thông tin cơ bản</h3>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-6">

                                        <div class="col-span-1 md:col-span-2 space-y-2">
                                            <label class="block text-sm font-medium text-text-main-light dark:text-text-main-dark">
                                                Tên nhân viên <span class="text-red-500">*</span>
                                            </label>
                                            <input type="text" th:field="*{fullName}" placeholder="Nhập tên nhân viên"
                                                   class="block w-full rounded-lg border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark/50 text-text-main-light dark:text-text-main-dark shadow-sm focus:border-primary focus:ring-primary sm:text-sm h-11 px-3 py-2" />
                                        </div>

                                        <div class="space-y-2">
                                            <label class="block text-sm font-medium text-text-main-light dark:text-text-main-dark">
                                                Vai trò
                                            </label>
                                            <select th:field="*{roleU}"
                                                    class="block w-full rounded-lg border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark/50 text-text-main-light dark:text-text-main-dark shadow-sm focus:border-primary focus:ring-primary sm:text-sm h-11 px-3">
                                                <option value="user">Nhân viên</option>
                                                <option value="Admin">Chủ cửa hàng</option>
                                            </select>
                                        </div>

                                        <div class="space-y-2">
                                            <label class="block text-sm font-medium text-text-main-light dark:text-text-main-dark">
                                                Số điện thoại
                                            </label>
                                            <div class="relative">
                                                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                                                    <span class="material-symbols-outlined text-text-secondary-light dark:text-text-secondary-dark text-[20px]">call</span>
                                                </div>
                                                <input type="tel" th:field="*{phone}" placeholder="09xx xxx xxx"
                                                       class="block w-full rounded-lg border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark/50 text-text-main-light dark:text-text-main-dark shadow-sm focus:border-primary focus:ring-primary sm:text-sm pl-10 h-11" />
                                            </div>
                                        </div>

                                        <div class="col-span-1 md:col-span-2 space-y-2">
                                            <label class="block text-sm font-medium text-text-main-light dark:text-text-main-dark">
                                                Email <span class="text-red-500">*</span>
                                            </label>
                                            <div class="relative">
                                                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                                                    <span class="material-symbols-outlined text-text-secondary-light dark:text-text-secondary-dark text-[20px]">mail</span>
                                                </div>
                                                <input type="email" th:field="*{email}" placeholder="email@example.com"
                                                       class="block w-full rounded-lg border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark/50 text-text-main-light dark:text-text-main-dark shadow-sm focus:border-primary focus:ring-primary sm:text-sm pl-10 h-11" />
                                            </div>
                                        </div>

                                        <div class="space-y-2">
                                            <label class="block text-sm font-medium text-text-main-light dark:text-text-main-dark">
                                                Giới tính
                                            </label>
                                            <select th:field="*{sex}"
                                                    class="block w-full rounded-lg border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark/50 text-text-main-light dark:text-text-main-dark shadow-sm focus:border-primary focus:ring-primary sm:text-sm h-11 px-3">
                                                <option value="true">Nam</option>
                                                <option value="false">Nữ</option>
                                            </select>
                                        </div>

                                        <div class="space-y-2">
                                            <label class="block text-sm font-medium text-text-main-light dark:text-text-main-dark">
                                                Ngày sinh
                                            </label>
                                            <input type="date" th:field="*{bDay}"
                                                   class="block w-full rounded-lg border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark/50 text-text-main-light dark:text-text-main-dark shadow-sm focus:border-primary focus:ring-primary sm:text-sm h-11 px-3" />
                                        </div>

                                    </div>
                                </div>

                                <div class="bg-gray-50 dark:bg-[#202936] px-6 py-4 flex items-center justify-end gap-3 border-t border-border-light dark:border-border-dark">
                                    <a th:href="@{/admin/employee}"
                                       class="rounded-lg border border-border-light dark:border-border-dark bg-white dark:bg-transparent px-5 py-2.5 text-sm font-medium text-text-main-light dark:text-text-main-dark shadow-sm hover:bg-gray-50 dark:hover:bg-background-dark/50 transition-all">
                                        Quay lại
                                    </a>
                                    <button type="submit"
                                            class="rounded-lg bg-primary px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-blue-600 transition-all flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px]">save</span>
                                        Lưu thay đổi
                                    </button>
                                </div>

                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>

    <script>
        const avatarContainer = document.getElementById("avatarContainer");
        const avatarInput = document.getElementById("avatarInput");
        const avatarPreview = document.getElementById("avatarPreview");

        avatarContainer.addEventListener("click", function () {
            avatarInput.click();
        });

        avatarInput.addEventListener("change", function (event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    avatarPreview.style.backgroundImage = `url('${e.target.result}')`;
                }
                reader.readAsDataURL(file);
            }
        });
    </script>
</body>
</html>