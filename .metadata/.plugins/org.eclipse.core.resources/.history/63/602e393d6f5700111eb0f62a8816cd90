package khanh.ntu.controllers;

import java.nio.file.*;
import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.ModelMap;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.multipart.MultipartFile;

import khanh.ntu.models.Product;
import khanh.ntu.services.BrandService;
import khanh.ntu.services.CategoryService;
import khanh.ntu.services.ProductService;

@Controller
public class MainController {
	@Autowired 
	private ProductService productService;
	
    @Autowired 
    private CategoryService categoryService;
    
    @Autowired 
    private BrandService brandService;
    
    
    @GetMapping("/admin/products")
    public String showProductPage(@RequestParam(value = "brandId", required = false) Integer brandId, 
						    		@RequestParam(value = "categoryId", required = false) Integer categoryId, 
						    		ModelMap m) {
    	List<Product> filteredProducts;
        
    	if (brandId != null) {

            filteredProducts = productService.getByBrand(brandId);
        } 
    	else if (categoryId != null) {
        	
            filteredProducts = productService.getByCategory(categoryId);
        } 
    	else {

            filteredProducts = productService.getAll();
        }
        m.addAttribute("products", filteredProducts);
        m.addAttribute("brands", brandService.getAll());
        m.addAttribute("categories", categoryService.getAll());
        
        m.addAttribute("currentBrand", brandId);
        m.addAttribute("currentCategory", categoryId);
        return "productPage"; 
    }
    
    @GetMapping("/admin/create")
    public String createForm(ModelMap m) {
        m.addAttribute("product", new Product());
        m.addAttribute("categories", categoryService.getAll());
        m.addAttribute("brands", brandService.getAll());
        return "createProduct";
    }
    
    @PostMapping("/admin/save")
    public String save(@ModelAttribute("product") Product product, @RequestParam("productImage") MultipartFile productImage) {
    	try {
            if (productImage != null && !productImage.isEmpty()) {
                String fileName = productImage.getOriginalFilename();
                String uploadDir = "D:/Learn/Web Exercises/QuanLyCuaHangDoChoi/QuanLyCuaHangDoChoi/Images/Products";
                
                Path uploadPath = Paths.get(uploadDir);
                if (!Files.exists(uploadPath)) {
                    Files.createDirectories(uploadPath);
                }
                
                Path filePath = uploadPath.resolve(fileName);
                Files.copy(productImage.getInputStream(), filePath, StandardCopyOption.REPLACE_EXISTING);
                
                product.setImageUrl("/Images/Products/" + fileName);
            }
            
            // Mặc định sản phẩm mới tạo sẽ ở trạng thái đang bán
            product.setIsActive(true); 

            // 2. Gọi Service để xử lý lưu sản phẩm và tự động tạo mã SKU đặc biệt
            productService.saveProductWithSku(product);
            
        } catch (IOException e) {
            e.printStackTrace();
            // Bạn có thể log lỗi hoặc đẩy thông báo lỗi ra giao diện nếu muốn
        }
        return "redirect:/admin/products";
    }
    
    @GetMapping("/admin/edit/{id}")
    public String editForm(@PathVariable("id") Integer id, ModelMap model) {
        model.addAttribute("product", productService.getById(id));
        model.addAttribute("categories", categoryService.getAll());
        model.addAttribute("brands", brandService.getAll());
        return "editProduct";
    }
    
    @GetMapping("/admin/delete/{id}")
    public String delete(@PathVariable("id") Integer id) {
        productService.delete(id);
        return "redirect:/admin/products";
    }
}
