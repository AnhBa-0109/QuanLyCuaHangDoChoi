<!DOCTYPE html>
<html class="light" lang="vi" xmlns:th="http://www.thymeleaf.org">
<head th:replace="~{fragments/head :: head_info}"></head>

<body class="bg-background-light dark:bg-background-dark h-screen flex overflow-hidden">

    <aside th:replace="~{fragments/sidebar :: sidebar}"></aside>

    <div class="flex-1 flex flex-col">
        <header th:replace="~{fragments/header :: header}"></header>

        <main class="flex-1 overflow-y-auto p-4 md:p-8">
            <div class="mx-auto flex flex-col gap-6">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h1 class="text-2xl font-black text-text-main-light dark:text-text-main-dark tracking-tight mb-2">Tạo Sản phẩm Mới</h1>
                        <p class="text-text-sec-light dark:text-text-sec-dark text-base max-w-2xl">Nhập thông tin chi tiết cho model kit, dụng cụ hoặc phụ kiện mới để thêm vào kho hàng.</p>
                    </div>
                </div>

                <form th:action="@{/admin/save}" th:object="${product}" method="post" enctype="multipart/form-data" novalidate="novalidate">
                    
                    <div th:if="${#fields.hasErrors('global')}" th:errors="*{global}" class="text-red-500 text-sm mb-4"></div>
                    
                    <div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-sm border border-border-light dark:border-border-dark overflow-hidden">
                        <div class="p-6 md:p-8 flex flex-col gap-8">
                            
                            <div class="flex flex-col gap-6">
                                <h3 class="text-lg font-bold text-text-main-light dark:text-text-main-dark border-b border-border-light dark:border-border-dark pb-2">Thông tin cơ bản</h3>
                                <div class="grid grid-cols-1 gap-6">
                                    <label class="flex flex-col gap-2">
                                        <span class="text-sm font-semibold text-text-main-light dark:text-text-main-dark">Tên sản phẩm <span class="text-red-500">*</span></span>
                                        <input type="text" th:field="*{productName}" placeholder="Ví dụ: MG Gundam Barbatos 1/100"  required
                                               class="w-full h-12 px-4 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark text-text-main-light dark:text-text-main-dark placeholder-text-sec-light focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none" />
                                        <span th:if="${#fields.hasErrors('productName')}" th:errors="*{productName}" class="text-red-500 text-xs font-medium"></span>
                                    </label>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    
                                    <div class="flex flex-col gap-2">
                                        <span class="text-sm font-semibold text-text-main-light dark:text-text-main-dark">
                                            Danh mục Brand <span class="text-red-500">*</span>
                                        </span>
                                        <div class="flex items-center gap-2">
                                            <div class="flex-1 relative">
                                                <select id="BrandID" th:field="*{brand.brandId}" class="select-arrow w-full h-12 px-4 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark text-text-main-light dark:text-text-main-dark focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none cursor-pointer use-select2" size="5">
                                                    <option value="">-- Chọn Brand --</option>
                                                    <option th:each="b : ${brands}" th:value="${b.brandId}" th:text="${b.brandName}"></option>
                                                </select>
                                            </div>
                                            <button type="button" onclick="openModal('brand')" class="w-12 h-12 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark text-text-sec-light hover:border-primary hover:text-primary transition-colors focus:ring-2 focus:ring-primary" title="Thêm Brand mới">
                                                <span class="material-symbols-outlined">add</span>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="flex flex-col gap-2">
                                        <span class="text-sm font-semibold text-text-main-light dark:text-text-main-dark">
                                            Danh mục Loại <span class="text-red-500">*</span>
                                        </span>
                                        <div class="flex items-center gap-2">
                                            <div class="flex-1 relative">
                                                <select id="CategoryID" th:field="*{category.categoryId}" class="select-arrow w-full h-12 px-4 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark text-text-main-light dark:text-text-main-dark focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none cursor-pointer use-select2" size="5">
                                                    <option value="">-- Chọn Loại --</option>
                                                    <option th:each="c : ${categories}" th:value="${c.categoryId}" th:text="${c.categoryName}"></option>
                                                </select>
                                            </div>
                                            <button type="button" onclick="openModal('category')" class="w-12 h-12 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark text-text-sec-light hover:border-primary hover:text-primary transition-colors focus:ring-2 focus:ring-primary" title="Thêm Category mới">
                                                <span class="material-symbols-outlined">add</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="flex flex-col gap-6">
                                <h3 class="text-lg font-bold text-text-main-light dark:text-text-main-dark border-b border-border-light dark:border-border-dark pb-2">Giá &amp; Kho hàng</h3>
                                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                    <label class="flex flex-col gap-2">
                                        <span class="text-sm font-semibold text-text-main-light dark:text-text-main-dark">Giá nhập (VNĐ) <span class="text-red-500">*</span></span>
                                        <div class="relative">
                                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-text-sec-light dark:text-text-sec-dark material-symbols-outlined text-[20px]">payments</span>
                                            <input type="number" th:field="*{importPrice}"  required
                                                   class="w-full h-12 pl-12 pr-4 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark text-text-main-light dark:text-text-main-dark placeholder-text-sec-light focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none" />
                                        </div>
                                        <span th:if="${#fields.hasErrors('importPrice')}" th:errors="*{importPrice}" class="text-red-500 text-xs font-medium"></span>
                                    </label>

                                    <label class="flex flex-col gap-2">
                                        <span class="text-sm font-semibold text-text-main-light dark:text-text-main-dark">Giá bán (VNĐ) <span class="text-red-500">*</span></span>
                                        <div class="relative">
                                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-text-sec-light dark:text-text-sec-dark material-symbols-outlined text-[20px]">sell</span>
                                            <input type="number" th:field="*{sellPrice}" required
                                                   class="w-full h-12 pl-12 pr-4 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark text-text-main-light dark:text-text-main-dark placeholder-text-sec-light focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none" />
                                        </div>
                                        <span th:if="${#fields.hasErrors('sellPrice')}" th:errors="*{sellPrice}" class="text-red-500 text-xs font-medium"></span>
                                    </label>

                                    <label class="flex flex-col gap-2">
                                        <span class="text-sm font-semibold text-text-main-light dark:text-text-main-dark">Số lượng tồn kho <span class="text-red-500">*</span></span>
                                        <div class="relative">
                                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-text-sec-light dark:text-text-sec-dark material-symbols-outlined text-[20px]">inventory</span>
                                            <input type="number" th:field="*{quantity}" required
                                                   class="w-full h-12 pl-12 pr-4 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark text-text-main-light dark:text-text-main-dark placeholder-text-sec-light focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none" />
                                        </div>
                                        <span th:if="${#fields.hasErrors('quantity')}" th:errors="*{quantity}" class="text-red-500 text-xs font-medium"></span>
                                    </label>
                                </div>
                            </div>

                            <div class="flex flex-col gap-6">
                                <h3 class="text-lg font-bold text-text-main-light dark:text-text-main-dark border-b border-border-light dark:border-border-dark pb-2">Hình ảnh sản phẩm</h3>
                                <div onclick="document.getElementById('productImageInput').click()" class="flex flex-col gap-4">
                                    <div class="group relative flex flex-col items-center justify-center w-full h-64 border-2 border-dashed border-border-light dark:border-border-dark rounded-xl bg-background-light/50 dark:bg-background-dark/30 hover:bg-background-light hover:border-primary/50 dark:hover:bg-background-dark transition-all cursor-pointer">
                                        <div class="flex flex-col items-center justify-center pt-5 pb-6 text-center px-4">
                                            <div class="mb-4 p-4 rounded-full bg-white dark:bg-surface-dark shadow-sm group-hover:scale-110 transition-transform duration-300">
                                                <span class="material-symbols-outlined text-primary text-4xl">cloud_upload</span>
                                            </div>
                                            <p class="mb-2 text-sm text-text-main-light dark:text-text-main-dark font-medium">
                                                <span class="font-bold text-primary">Nhấp để tải lên</span> hoặc kéo thả vào đây
                                            </p>
                                            <p class="text-xs text-text-sec-light dark:text-text-sec-dark">PNG, JPG hoặc WEBP (Tối đa 10MB)</p>
                                        </div>
                                        <input id="productImageInput" name="ProductImage" accept="image/*" class="hidden" type="file" />
                                    </div>
                                </div>
                                <img id="imagePreview" class="hidden w-40 h-40 object-cover rounded-lg border mt-4" />
                            </div>

                            <div class="flex items-center justify-end gap-4 pt-4 mt-4 border-t border-border-light dark:border-border-dark">
                                <a th:href="@{/admin/products}">
                                    <button class="px-6 py-3 rounded-lg border border-border-light dark:border-border-dark text-text-sec-light dark:text-text-sec-dark font-medium hover:bg-background-light dark:hover:bg-background-dark hover:text-text-main-light dark:hover:text-text-main-dark transition-colors focus:ring-2 focus:ring-gray-200" type="button">
                                        Hủy bỏ
                                    </button>
                                </a>

                                <button class="flex items-center gap-2 px-8 py-3 rounded-lg bg-primary text-white font-semibold shadow-lg shadow-blue-500/20 hover:bg-blue-600 hover:shadow-blue-500/30 transition-all focus:ring-2 focus:ring-primary focus:ring-offset-2 dark:focus:ring-offset-surface-dark" type="submit">
                                    <span class="material-symbols-outlined text-[20px]">add_circle</span>
                                    Tạo Sản Phẩm
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div id="addModal" class="fixed inset-0 bg-black/40 hidden items-center justify-center z-50">
                <div class="bg-white dark:bg-surface-dark rounded-xl p-6 w-96 flex flex-col gap-3">
                    <h3 id="modalTitle" class="text-lg font-bold mb-4"></h3>

                    <input id="modalNameInput" class="w-full h-12 px-4 rounded-lg border" placeholder="" />
                    <input id="modalCodeInput" class="w-full h-12 px-4 rounded-lg border" placeholder="" />
                    
                    <div class="flex justify-end gap-2 mt-4">
                        <button type="button" onclick="closeModal()" class="px-4 py-2 border rounded-lg">Hủy</button>
                        <button type="button" onclick="saveItem()" class="px-4 py-2 bg-primary text-white rounded-lg">Lưu</button>
                    </div>
                </div>
            </div>

            <script th:inline="javascript">
                let currentType = "";
                const input = document.getElementById('productImageInput');
                const preview = document.getElementById('imagePreview');

                input.addEventListener('change', function () {
                    if (this.files && this.files[0]) {
                        const reader = new FileReader();
                        reader.onload = e => {
                            preview.src = e.target.result;
                            preview.classList.remove('hidden');
                        };
                        reader.readAsDataURL(this.files[0]);
                    }
                });

                function openModal(type) {
                    currentType = type;

                    document.getElementById('modalTitle').innerText =
                        type === 'brand' ? 'Thêm Brand mới' : 'Thêm Category mới';

                    document.getElementById('modalNameInput').placeholder =
                        type === 'brand' ? 'Tên Brand' : 'Tên Category';

                    document.getElementById('modalCodeInput').placeholder =
                        type === 'brand' ? 'Brand Code' : 'Category Code';

                    document.getElementById('modalNameInput').value = '';
                    document.getElementById('modalCodeInput').value = '';

                    document.getElementById('addModal').classList.remove('hidden');
                    document.getElementById('addModal').classList.add('flex');
                }

                function closeModal() {
                    document.getElementById('addModal').classList.add('hidden');
                }

                function saveItem() {
                    const name = document.getElementById('modalNameInput').value.trim();
                    const code = document.getElementById('modalCodeInput').value.trim();

                    if (!name) {
                        alert('Không được để trống');
                        return;
                    }
                    if (!code) {
                        alert('Không được để trống');
                        return;
                    }

                    let url = '';
                    let selectId = '';

                    if (currentType === 'brand') {
                        // Lưu ý: Cần tạo 1 API @PostMapping("/admin/createBrandAjax") trong Controller của Spring Boot
                        url = '/admin/createBrandAjax'; 
                        selectId = 'BrandID';
                    }
                    else {
                        // Lưu ý: Cần tạo 1 API @PostMapping("/admin/createCategoryAjax") trong Controller của Spring Boot
                        url = '/admin/createCategoryAjax';
                        selectId = 'CategoryID';
                    }

                    fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            BrandName: currentType === 'brand' ? name : null,
                            BrandCode: currentType === 'brand' ? code : null,
                            CategoriesName: currentType === 'category' ? name : null,
                            CategoryCode: currentType === 'category' ? code : null
                        })
                    })
                        .then(res => res.json())
                        .then(data => {
                            console.log("PARSED DATA:", data);

                            if (data.error) {
                                alert(data.error);
                                return;
                            }

                            const select = document.getElementById(selectId);
                            const option = new Option(data.name, data.id, true, true);
                            select.add(option);

                            closeModal();
                        })
                        .catch(err => {
                            console.error(err);
                            alert("Có lỗi JS xảy ra: " + err.message);
                        });
                }

                $(document).ready(function () {
                    $('.use-select2').select2({
                        width: '100%',
                        placeholder: "-- Chọn --",
                        allowClear: true
                    });
                });
            </script>
            </main>
    </div>
</body>
</html>